# Mode: 'local' (bind mounts + Docker socket) or 'ssh' (SSH to remote host)
PODSYNC_MODE=local

# Server port for podsync-ui
PORT=3000

# Podsync container name (used for restart)
PODSYNC_CONTAINER_NAME=podsync

# Paths to config and data
# In 'local' mode: local filesystem paths (bind mounts)
# In 'ssh' mode: remote paths on the SSH host
PODSYNC_CONFIG_PATH=/app/config/config.toml
PODSYNC_DATA_DIR=/app/data

# Sidecar config directory (always local - stores auth.json)
SIDECAR_CONFIG_DIR=/app/sidecar-config

# ─── SSH Settings (only used when PODSYNC_MODE=ssh) ───

# SSH connection
SSH_HOST=192.168.1.100
SSH_PORT=22
SSH_USERNAME=user

# SSH auth: use password OR key (not both)
SSH_PASSWORD=
SSH_KEY_PATH=/app/ssh/id_rsa
SSH_KEY_PASSPHRASE=
